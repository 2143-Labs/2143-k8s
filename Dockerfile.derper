FROM golang:1.26-bookworm@sha256:386d475a660466863d9f8c766fec64d7fdad3edac2c6a05020c09534d71edb4b AS build
RUN CGO_ENABLED=0 go install tailscale.com/cmd/derper@v1.98.5

FROM alpine:3.21@sha256:48b0309ca019d89d40f670aa1bc06e426dc0931948452e8491e3d65087abc07d
RUN apk add --no-cache ca-certificates
COPY --from=build /go/bin/derper /usr/local/bin/derper
EXPOSE 8080 3478/udp
ENTRYPOINT ["/usr/local/bin/derper"]
